# ZenPass 禪流 - 環境設定範本
# 複製此檔案為 .env 並填入你的真實資料
# 警告：永遠不要將 .env commit 到 Git！

PORT=3001
NODE_ENV=development

# JWT Secret — 請用以下指令生成：
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_replace_me

# 數據庫路徑
DB_PATH=./data/zenpass.db

# Stripe — 請到 https://dashboard.stripe.com/apikeys 獲取
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# CORS — 允許的前端來源
CORS_ORIGIN=https://davidchoy1689-tech.github.io

# FPS (轉數快) — 你的 FPS 商戶資料
FPS_MERCHANT_ID=your_fps_merchant_id
FPS_API_KEY=your_fps_api_key

# PayMe — 你的 PayMe 商戶資料
PAYME_MERCHANT_ID=your_payme_merchant_id
PAYME_API_KEY=your_payme_api_key
