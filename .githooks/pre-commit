#!/bin/sh
# ZenPass 禪流 — Pre-commit Hook
# 自動執行測試，失敗則 block commit
#
# 安裝：git config core.hooksPath .githooks

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo ""
echo "🧪 ZenPass Pre-commit Hook: Running tests..."
echo ""

# 檢查是否有 staged 的檔案跟 backend 有關
STAGED_FILES=$(git diff --cached --name-only)
HAS_BACKEND_CHANGES=$(echo "$STAGED_FILES" | grep -c "^backend/" || true)
HAS_FRONTEND_CHANGES=$(echo "$STAGED_FILES" | grep -c "^frontend/" || true)

if [ "$HAS_BACKEND_CHANGES" -eq 0 ] && [ "$HAS_FRONTEND_CHANGES" -eq 0 ]; then
  echo "${YELLOW}⚠️  沒有 backend 或 frontend 改動，跳過測試${NC}"
  echo ""
  exit 0
fi

# ---- Backend Tests ----
if [ "$HAS_BACKEND_CHANGES" -gt 0 ]; then
  echo "${YELLOW}📦 Backend 有改動，執行 backend tests...${NC}"

  # 檢查 node_modules 是否存在
  if [ ! -d "backend/node_modules" ]; then
    echo "${YELLOW}📦 安裝 backend dependencies...${NC}"
    (cd backend && npm install) || {
      echo "${RED}❌ npm install 失敗${NC}"
      exit 1
    }
  fi

  # 執行所有 test（若 package.json 有 test script）
  if grep -q '"test"' backend/package.json 2>/dev/null; then
    (cd backend && npm test 2>&1) || {
      echo ""
      echo "${RED}❌ Backend tests FAILED — commit 被阻止${NC}"
      echo "${YELLOW}請修正測試錯誤後再 commit${NC}"
      echo ""
      exit 1
    }
    echo "${GREEN}✅ Backend tests passed${NC}"
  else
    echo "${YELLOW}⚠️  backend/package.json 未有 test script，跳過${NC}"
  fi

  # 如果有 test 目錄，直接執行指定 test files
  if [ -d "backend/tests" ]; then
    echo "${YELLOW}📋 執行 backend/tests/ 目錄下的測試...${NC}"
    TEST_FILES=$(find backend/tests -name "*.js" 2>/dev/null | grep -v node_modules)
    if [ -n "$TEST_FILES" ]; then
      for tf in $TEST_FILES; do
        echo "   測試: $tf"
        node "$tf" 2>&1 || {
          echo ""
          echo "${RED}❌ 測試失敗: $tf${NC}"
          echo "${RED}❌ Commit 被阻止 — 請修正測試錯誤後再 commit${NC}"
          echo ""
          exit 1
        }
      done
    fi
    echo "${GREEN}✅ All backend tests passed${NC}"
  fi
fi

# ---- Frontend Tests (check for basic issues) ----
if [ "$HAS_FRONTEND_CHANGES" -gt 0 ]; then
  echo "${YELLOW}🎨 Frontend 有改動，檢查 HTML 結構...${NC}"

  # 檢查改動的 HTML 檔案是否有基本錯誤
  for f in $(echo "$STAGED_FILES" | grep "\.html$" || true); do
    if [ -f "$f" ]; then
      # 檢查是否有未閉合的 <script> 或 <style> 標籤
      SCRIPT_OPEN=$(grep -c '<script' "$f" 2>/dev/null || echo 0)
      SCRIPT_CLOSE=$(grep -c '</script>' "$f" 2>/dev/null || echo 0)
      if [ "$SCRIPT_OPEN" -ne "$SCRIPT_CLOSE" ]; then
        echo "${RED}❌ $f: <script> 標籤數量不匹配 (open=$SCRIPT_OPEN, close=$SCRIPT_CLOSE)${NC}"
        exit 1
      fi

      STYLE_OPEN=$(grep -c '<style' "$f" 2>/dev/null || echo 0)
      STYLE_CLOSE=$(grep -c '</style>' "$f" 2>/dev/null || echo 0)
      if [ "$STYLE_OPEN" -ne "$STYLE_CLOSE" ]; then
        echo "${RED}❌ $f: <style> 標籤數量不匹配 (open=$STYLE_OPEN, close=$STYLE_CLOSE)${NC}"
        exit 1
      fi

      echo "  ✅ $f — HTML 結構正常"
    fi
  done
  echo "${GREEN}✅ Frontend checks passed${NC}"
fi

echo ""
echo "${GREEN}🎉 All checks passed! Commit 繼續進行。${NC}"
echo ""
